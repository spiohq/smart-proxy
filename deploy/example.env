# =============================================================================
# Smart Proxy for SP-API  -  Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# All values shown are defaults  -  uncomment and change only what you need.

# -----------------------------------------------------------------------------
# Server ports (set to 0 to disable a region)
# -----------------------------------------------------------------------------
SP_PROXY_PORT_EU=8080
SP_PROXY_PORT_NA=8081
SP_PROXY_PORT_FE=8082
SP_PROXY_PORT_DASHBOARD=9090
SP_PROXY_SHUTDOWN_TIMEOUT=30s

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
SP_PROXY_RATELIMIT_ENABLED=true
SP_PROXY_RATELIMIT_MODE=queue
SP_PROXY_RATELIMIT_QUEUE_TIMEOUT=60s
SP_PROXY_RATELIMIT_QUEUE_MAX_DEPTH=100
SP_PROXY_RATELIMIT_THROTTLE_FACTOR=0.8
SP_PROXY_BUCKET_TTL=2h

# -----------------------------------------------------------------------------
# Caching
# -----------------------------------------------------------------------------
SP_PROXY_CACHE_ENABLED=true
SP_PROXY_CACHE_MAX_MEMORY=268435456
SP_PROXY_CACHE_DEFAULT_TTL=60s
SP_PROXY_CACHE_EXCLUDE_PII=true

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
SP_PROXY_STORAGE_BACKEND=sqlite
SP_PROXY_SQLITE_PATH=/data/sp-proxy.db

# -----------------------------------------------------------------------------
# Body storage
# -----------------------------------------------------------------------------
SP_PROXY_BODIES_ENABLED=true
SP_PROXY_BODIES_PATH=/data/bodies
# Backend for recent/ and archive/ tiers: "local" or "s3". The active hour
# (current/) is always written to SP_PROXY_BODIES_PATH on local disk.
SP_PROXY_BODIES_BACKEND=local
SP_PROXY_BODIES_RECENT_MAX_AGE=24h
SP_PROXY_BODIES_ARCHIVE_MAX_AGE=720h
SP_PROXY_BODIES_COMPRESSION=zstd
SP_PROXY_BODIES_MAX_CAPTURE_SIZE=262144
# Hard cap across current/+recent/+archive/ (bytes). 0 disables size eviction.
SP_PROXY_BODIES_MAX_BYTES=8589934592

# -----------------------------------------------------------------------------
# S3 (only used when SP_PROXY_BODIES_BACKEND=s3)
# -----------------------------------------------------------------------------
# SP_PROXY_S3_BUCKET=my-proxy-bodies
# SP_PROXY_S3_REGION=eu-central-1
# SP_PROXY_S3_ENDPOINT=   # set for MinIO, R2, etc.; leave blank for AWS
# SP_PROXY_S3_ACCESS_KEY= # optional; falls back to default credential chain
# SP_PROXY_S3_SECRET_KEY=
# SP_PROXY_S3_PATH_STYLE=false  # true for MinIO

# -----------------------------------------------------------------------------
# Purge retention
# -----------------------------------------------------------------------------
SP_PROXY_PURGE_METADATA_RETENTION=720h
SP_PROXY_PURGE_AUDIT_RETENTION=8760h
