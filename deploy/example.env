# =============================================================================
# Smart Proxy for SP-API  -  Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# All values shown are defaults  -  uncomment and change only what you need.

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# Set to "production" in production deployments. In production mode the proxy
# refuses to start with insecure S3 endpoints and emits dpp_compliance_warning
# audit events for any non-DPP-conformant configuration choice (see below).
SP_PROXY_ENV=development

# -----------------------------------------------------------------------------
# DPP / AUP Compliance (DPP §1.2, §1.7, §2.1, §2.6)
# -----------------------------------------------------------------------------
# These defaults are DPP-conformant. Lowering them weakens compliance and
# triggers production-mode warnings recorded as audit events. See
# docs/DPP_COMPLIANCE.md for the full reference.

# DPP §2.6 -- redact unknown SP-API endpoint bodies by default.
# Set to false ONLY if all upstream endpoints are mapped in the registry.
SP_PROXY_PII_FAIL_CLOSED=true

# DPP §2.6 -- comma-separated extra query-param names to treat as PII
# (case-insensitive). buyerEmail and buyerName are always redacted.
# SP_PROXY_PII_QUERY_PARAMS=customField1,customField2

# DPP §1.2 -- dashboard bind address. 127.0.0.1 prevents accidental network
# exposure of the unauthenticated dashboard. Containers should set this to
# 0.0.0.0 inside and use a host-side 127.0.0.1:9090:9090 port mapping.
SP_PROXY_DASHBOARD_BIND_ADDR=127.0.0.1

# -----------------------------------------------------------------------------
# Server ports (set to 0 to disable a region)
# -----------------------------------------------------------------------------
SP_PROXY_PORT_EU=8080
SP_PROXY_PORT_NA=8081
SP_PROXY_PORT_FE=8082
SP_PROXY_PORT_DASHBOARD=9090
SP_PROXY_SHUTDOWN_TIMEOUT=30s

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
SP_PROXY_RATELIMIT_ENABLED=true
SP_PROXY_RATELIMIT_MODE=queue
SP_PROXY_RATELIMIT_QUEUE_TIMEOUT=60s
SP_PROXY_RATELIMIT_QUEUE_MAX_DEPTH=100
SP_PROXY_RATELIMIT_THROTTLE_FACTOR=0.8
SP_PROXY_BUCKET_TTL=2h

# -----------------------------------------------------------------------------
# Caching
# -----------------------------------------------------------------------------
SP_PROXY_CACHE_ENABLED=true
SP_PROXY_CACHE_MAX_MEMORY=268435456
SP_PROXY_CACHE_DEFAULT_TTL=60s
SP_PROXY_CACHE_EXCLUDE_PII=true

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
SP_PROXY_STORAGE_BACKEND=sqlite
SP_PROXY_SQLITE_PATH=/data/sp-proxy.db

# -----------------------------------------------------------------------------
# Body storage
# -----------------------------------------------------------------------------
SP_PROXY_BODIES_ENABLED=true
SP_PROXY_BODIES_PATH=/data/bodies
# Backend for recent/ and archive/ tiers: "local" or "s3". The active hour
# (current/) is always written to SP_PROXY_BODIES_PATH on local disk.
SP_PROXY_BODIES_BACKEND=local
SP_PROXY_BODIES_RECENT_MAX_AGE=24h
SP_PROXY_BODIES_ARCHIVE_MAX_AGE=720h
SP_PROXY_BODIES_COMPRESSION=zstd
SP_PROXY_BODIES_MAX_CAPTURE_SIZE=262144
# Hard cap across current/+recent/+archive/ (bytes). 0 disables size eviction.
SP_PROXY_BODIES_MAX_BYTES=8589934592

# -----------------------------------------------------------------------------
# S3 (only used when SP_PROXY_BODIES_BACKEND=s3)
# -----------------------------------------------------------------------------
# SP_PROXY_S3_BUCKET=my-proxy-bodies
# SP_PROXY_S3_REGION=eu-central-1
# SP_PROXY_S3_ENDPOINT=   # set for MinIO, R2, etc.; leave blank for AWS
# SP_PROXY_S3_ACCESS_KEY= # optional; falls back to default credential chain
# SP_PROXY_S3_SECRET_KEY=
# SP_PROXY_S3_PATH_STYLE=false  # true for MinIO
# DPP §2.4 -- enforce server-side encryption on every PutObject. Pair with
# a bucket policy that denies unencrypted uploads. Required for production.
# SP_PROXY_S3_SSE=AES256                  # SSE-S3
# SP_PROXY_S3_SSE=aws:kms                 # SSE-KMS (set SP_PROXY_S3_SSE_KMS_KEY)
# SP_PROXY_S3_SSE_KMS_KEY=alias/proxy

# -----------------------------------------------------------------------------
# Purge retention (DPP §1.7, §2.1, §2.6)
# -----------------------------------------------------------------------------
# DPP §1.7: non-PII metadata <= 18 months. Default 30 days.
SP_PROXY_PURGE_METADATA_RETENTION=720h
# DPP §2.6: audit logs >= 12 months. Default 9504h (~13 months) for buffer.
SP_PROXY_PURGE_AUDIT_RETENTION=9504h
